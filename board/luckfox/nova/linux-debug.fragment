# Hunt for the corrupted-timer panic: debugobjects names the function that
# armed a timer living in freed memory before it fires.
CONFIG_DEBUG_OBJECTS=y
CONFIG_DEBUG_OBJECTS_FREE=y
CONFIG_DEBUG_OBJECTS_TIMERS=y
CONFIG_DEBUG_OBJECTS_WORK=y
CONFIG_DEBUG_OBJECTS_ENABLE_DEFAULT=1
# catch the use-after-free writer too: poison freed slab objects
CONFIG_SLUB_DEBUG=y
CONFIG_SLUB_DEBUG_ON=y
