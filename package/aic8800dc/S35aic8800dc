#!/bin/sh
# Load the AIC8800DC SDIO WiFi modules (no module autoloader in this rootfs).
# aic8800_bsp registers the SDIO function and loads firmware from
# /lib/firmware/aic8800_sdio/aic8800DC; aic8800_fdrv brings up cfg80211.

case "$1" in
	start)
		printf 'Loading AIC8800DC WiFi: '
		modprobe aic8800_bsp 2>/dev/null
		modprobe aic8800_fdrv 2>/dev/null
		echo OK
		;;
	stop)
		modprobe -r aic8800_fdrv 2>/dev/null
		modprobe -r aic8800_bsp 2>/dev/null
		;;
	*)
		echo "Usage: $0 {start|stop}"
		exit 1
		;;
esac
